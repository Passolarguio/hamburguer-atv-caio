module.exports = (sequelize, DataTypes) => {
  const Avaliacao = sequelize.define('Avaliacao', {
    nota: {
      type: DataTypes.INTEGER,
      allowNull: false,
      validate: {
        min: 1,
        max: 5
      }
    },
    pedidoId: {
      type: DataTypes.INTEGER,
      allowNull: false
    }
  });

  Avaliacao.associate = (models) => {
    Avaliacao.belongsTo(models.Pedido, {
      foreignKey: 'pedido_id',
      as: 'pedido'
    });
  };

  return Avaliacao;
};